{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-open-path",
    "os:default",
    "fs:default",
    "fs:allow-appdata-write-recursive",
    "fs:allow-open",
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        {
          "path": "$APPLOCALDATA/**"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$HOME/Library/Application Support/**"
        },
        {
          "path": "$APPLOCALDATA/**/.*"
        },
        {
          "path": "$APPDATA/**/.*"
        },
        {
          "path": "$HOME/Library/Application Support/**/.*"
        }
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        {
          "path": "$APPLOCALDATA/**"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$HOME/Library/Application Support/**"
        },
        {
          "path": "$APPLOCALDATA/**/.*"
        },
        {
          "path": "$APPDATA/**/.*"
        },
        {
          "path": "$HOME/Library/Application Support/**/.*"
        }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        {
          "path": "$APPLOCALDATA/**"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$HOME/Library/Application Support/**"
        },
        {
          "path": "$APPLOCALDATA/**/.*"
        },
        {
          "path": "$APPDATA/**/.*"
        },
        {
          "path": "$HOME/Library/Application Support/**/.*"
        }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        {
          "path": "$APPLOCALDATA/**"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$HOME/Library/Application Support/**"
        },
        {
          "path": "$APPLOCALDATA/**/.*"
        },
        {
          "path": "$APPDATA/**/.*"
        },
        {
          "path": "$HOME/Library/Application Support/**/.*"
        }
      ]
    },
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPLOCALDATA/**"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$HOME/Library/Application Support/**"
        },
        {
          "path": "$APPLOCALDATA/**/.*"
        },
        {
          "path": "$APPDATA/**/.*"
        },
        {
          "path": "$HOME/Library/Application Support/**/.*"
        }
      ]
    },
    "core:webview:allow-set-webview-zoom",
    "core:webview:allow-set-webview-size",
    "dialog:default"
  ]
}
