{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:default",
    "fs:allow-appdata-write-recursive",
    "core:webview:allow-set-webview-zoom",
    "core:webview:allow-set-webview-size",
    "os:default"
  ]
}