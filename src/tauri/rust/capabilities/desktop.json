{
  "identifier": "desktop-capability",
  "platforms": ["macOS", "windows", "linux"],
  "windows": ["main"],
  "permissions": [
    "window-state:default",
    "fs:default",
    "fs:allow-appdata-write-recursive",
    "fs:allow-open",
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        {
          "path": "$APPLOCALDATA/**"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$HOME/Library/Application Support/**"
        },
        {
          "path": "$APPLOCALDATA/**/.*"
        },
        {
          "path": "$APPDATA/**/.*"
        },
        {
          "path": "$HOME/Library/Application Support/**/.*"
        }
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        {
          "path": "$APPLOCALDATA/**"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$HOME/Library/Application Support/**"
        },
        {
          "path": "$APPLOCALDATA/**/.*"
        },
        {
          "path": "$APPDATA/**/.*"
        },
        {
          "path": "$HOME/Library/Application Support/**/.*"
        }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        {
          "path": "$APPLOCALDATA/**"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$HOME/Library/Application Support/**"
        },
        {
          "path": "$APPLOCALDATA/**/.*"
        },
        {
          "path": "$APPDATA/**/.*"
        },
        {
          "path": "$HOME/Library/Application Support/**/.*"
        }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        {
          "path": "$APPLOCALDATA/**"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$HOME/Library/Application Support/**"
        },
        {
          "path": "$APPLOCALDATA/**/.*"
        },
        {
          "path": "$APPDATA/**/.*"
        },
        {
          "path": "$HOME/Library/Application Support/**/.*"
        }
      ]
    },
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPLOCALDATA/**"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$HOME/Library/Application Support/**"
        },
        {
          "path": "$APPLOCALDATA/**/.*"
        },
        {
          "path": "$APPDATA/**/.*"
        },
        {
          "path": "$HOME/Library/Application Support/**/.*"
        }
      ]
    },
    "os:default",
    "opener:allow-open-path",
    "opener:default",
    "dialog:default"
  ]
}
