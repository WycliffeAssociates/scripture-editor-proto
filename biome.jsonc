{
    "$schema": "https://biomejs.dev/schemas/2.2.2/schema.json",
    "vcs": {
        "enabled": false,
        "clientKind": "git",
        "useIgnoreFile": false
    },
    "files": {
        "ignoreUnknown": false,
        "includes": [
            "./src/**/*.{ts,tsx}",
            "lingui.config.js",
            "vite.config.ts",
            "vite.tauri.config.ts",
            "vite.web.config.ts",
            "vitest.config.ts"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4
    },
    "linter": {
        "enabled": true,
        "rules": {
            // "recommended": true,
            "style": {
                "useImportType": {
                    "level": "warn",
                    "fix": "safe",
                    "options": {
                        "style": "auto"
                    }
                }
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double"
        }
    },
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": "on",
                "recommended": true
            }
        }
    }
}
