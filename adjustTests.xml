        if (!memoryWrittenFile) {
            throw new Error("Metadata file not found in memory");
        }
        const memoryWrittenMetadata = JSON.parse(memoryWrittenFile);
        expect(memoryWrittenMetadata.ingredients).toHaveProperty(
