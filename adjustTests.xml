        expect(memoryWrittenMetadata.ingredients[expectedFilename].title).toBe(
            localizedBookTitle,
        );
    });
    test("addBook should not overwrite an existing file (as ingredient)", async () => {
        const existingIngredients = {
            "41-MAT.usfm": {
                checksum: { md5: "old-md5" },
                mimeType: "text/usfm",
                size: 12345,
