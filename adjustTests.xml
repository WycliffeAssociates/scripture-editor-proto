    const lockImmutablesOnCut = lockImmutableMarkersOnCut(editor);
    const cleanup = () => {
      unregisterTransformWhileTyping();
      redirectParaInsertionToLineBreakUnregister();
      keyDownUnregister();
      moveToAdjacentNodesUnregister();
      pasteCommand();
      lockImmutablesOnCut();
    };
