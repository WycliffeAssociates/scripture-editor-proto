    return node instanceof USFMNestedEditorNode;
}
export function isSerializedUSFMNestedEditorNode(
    node: SerializedLexicalNode,
): node is USFMNestedEditorNodeJSON {
    return node.type === USFM_NESTED_DECORATOR_TYPE;
}
