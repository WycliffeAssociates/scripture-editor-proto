                        }
                        withArrow
                        position="top"
                    >
                        <ActionIcon
                            data-testid={TESTING_IDS.sortToggleButton}
                            size="sm"
                            variant={isSortActive ? "filled" : "light"}
                            color={isSortActive ? "orange" : "gray"}
