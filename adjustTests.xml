        if (!metadataJson) {
            throw new Error("Metadata file not found");
        }
        const updatedMetadata = JSON.parse(metadataJson);
        expect(updatedMetadata.ingredients["41-MAT.usfm"].checksum.md5).toBe(
            "old-md5",
