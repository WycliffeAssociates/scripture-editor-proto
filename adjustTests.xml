#!/usr/bin/env python3
import os
import sys
import argparse
import time
import glob
import re
import json
import subprocess
from datetime import datetime, timezone

# --- Configuration ---
def find_project_root():
    path = os.getcwd()
    while path != os.path.dirname(path):
        if os.path.exists(os.path.join(path, ".tickets")) or os.path.exists(os.path.join(path, ".git")):
            return path
        path = os.path.dirname(path)
    return os.getcwd()

PROJECT_ROOT = find_project_root()
TICKETS_DIR = os.path.join(PROJECT_ROOT, ".tickets")
VALID_STATUSES = {"open", "in_progress", "closed"}
VALID_EFFORTS = {"trivial", "low", "medium", "hard", "giant"}

# --- Helpers ---

def ensure_dir():
    if not os.path.exists(TICKETS_DIR):
        os.makedirs(TICKETS_DIR)

def get_iso_date():
    return datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')

def parse_semver(tid):
    """Converts '1.2.10' -> (1, 2, 10). Returns None if not semver."""
    try:
        parts = [int(x) for x in tid.split('.')]
        return tuple(parts)
    except ValueError:
        return None

def get_next_id(parent_id=None):
    """Calculates next available ID."""
    tickets = get_all_tickets()
    existing_ids = list(tickets.keys())
    
    if parent_id is None:
        # Find highest top-level ID (no dots)
        max_id = 0
        for tid in existing_ids:
            parsed = parse_semver(tid)
            if parsed and len(parsed) == 1:
                if parsed[0] > max_id: max_id = parsed[0]
        return str(max_id + 1)
    else:
        # Find highest child of parent
        prefix = parent_id + "."
        parent_depth = len(parent_id.split('.'))
        max_child = 0
        
        for tid in existing_ids:
            if tid.startswith(prefix):
                parsed = parse_semver(tid)
                if parsed and len(parsed) == parent_depth + 1:
                    last_digit = parsed[-1]
                    if last_digit > max_child: max_child = last_digit
        
        return f"{parent_id}.{max_child + 1}"

def parse_ticket(filepath):
    with open(filepath, 'r', encoding='utf-8') as f:
        content = f.read()
    match = re.match(r'^---\n(.*?)\n---\n(.*)', content, re.DOTALL)
    if not match: return {}, content
    fm_text, body = match.group(1), match.group(2)
    metadata = {}
    for line in fm_text.split('\n'):
        if ':' in line:
            key, val = line.split(':', 1)
            key, val = key.strip(), val.strip()
            if val.startswith('[') and val.endswith(']'):
                inner = val[1:-1]
                metadata[key] = [x.strip() for x in inner.split(',') if x.strip()] if inner.strip() else []
            else:
                metadata[key] = val
    return metadata, body

def save_ticket(filepath, metadata, body):
    with open(filepath, 'w', encoding='utf-8') as f:
        f.write("---\n")
        order = ['id', 'status', 'effort', 'type', 'priority', 'deps', 'links', 'created', 'parent']
        for k in order:
            if k in metadata:
                v = metadata[k]
                if isinstance(v, list): f.write(f"{k}: [" + ", ".join(v) + "]\n")
                else: f.write(f"{k}: {v}\n")
        for k, v in metadata.items():
            if k not in order:
                 if isinstance(v, list): f.write(f"{k}: [" + ", ".join(v) + "]\n")
                 else: f.write(f"{k}: {v}\n")
        f.write("---\n")
        f.write(body)

def find_ticket(ticket_id):
    """Strict lookup. No fuzzy matching."""
    exact_path = os.path.join(TICKETS_DIR, f"{ticket_id}.md")
    if os.path.exists(exact_path):
        return exact_path
    
    print(f"Error: ticket '{ticket_id}' not found", file=sys.stderr)
    sys.exit(1)

def get_all_tickets():
    if not os.path.exists(TICKETS_DIR): return {}
    files = glob.glob(os.path.join(TICKETS_DIR, "*.md"))
    tickets = {}
    for f in files:
        meta, body = parse_ticket(f)
        tid = meta.get('id', os.path.basename(f).replace('.md', ''))
        tickets[tid] = {'meta': meta, 'body': body, 'path': f}
    return tickets

def extract_title(body):
    for line in body.split('\n'):
        if line.startswith('# '): return line[2:].strip()
    return "Untitled"

def get_descendants(root_id, all_tickets):
    descendants = set()
    children = [tid for tid, t in all_tickets.items() if t['meta'].get('parent') == root_id]
    for child in children:
        descendants.add(child)
        descendants.update(get_descendants(child, all_tickets))
    return descendants

# --- Commands ---

def cmd_create(args):
    ensure_dir()
    
    tid = None
    parent_ref = None

    # Strict ID Strategy Enforcement
    if args.id_override:
        tid = args.id_override
    elif args.parent:
        # Validate parent exists
        find_ticket(args.parent)
        tid = get_next_id(args.parent)
        parent_ref = args.parent
    elif args.epic:
        tid = get_next_id(None)
    else:
        print("Error: Ticket ID strategy required.", file=sys.stderr)
        print("You must use one of:", file=sys.stderr)
        print("  --id <val>    : Manual ID (e.g., 1.2)", file=sys.stderr)
        print("  --parent <val>: Auto-number as next child of parent (e.g., 1 -> 1.3)", file=sys.stderr)
        print("  --epic        : Auto-number as next Major Epic (e.g., 2)", file=sys.stderr)
        sys.exit(1)

    # Validate SemVer format
    if not parse_semver(tid):
        print(f"Error: ID '{tid}' is not valid. Must be in format 'X' or 'X.Y' (integers only).", file=sys.stderr)
        sys.exit(1)
    
    if os.path.exists(os.path.join(TICKETS_DIR, f"{tid}.md")):
        print(f"Error: Ticket {tid} already exists.", file=sys.stderr)
        sys.exit(1)

    filepath = os.path.join(TICKETS_DIR, f"{tid}.md")
    metadata = {
        "id": tid, "status": "open", "effort": args.effort,
        "deps": [], "links": [], "created": get_iso_date(),
        "type": args.type, "priority": args.priority,
    }
    
    if args.assignee: metadata["assignee"] = args.assignee
    else:
        try:
            u = subprocess.check_output(["git", "config", "user.name"], text=True).strip()
            if u: metadata["assignee"] = u
        except: pass
            
    if args.external_ref: metadata["external-ref"] = args.external_ref
    if parent_ref: metadata["parent"] = parent_ref
    
    # Handle implicit parenting from manual ID (optional but helpful?)
    # If user manually types 1.2, we infer parent is 1 if not explicitly set?
    # Let's keep it strict for now: explicit parent arg or inferred from auto-parent logic.
        
    title = args.title if args.title else "Untitled"
    body = f"# {title}\n\n"
    if args.description: body += f"{args.description}\n\n"
    if args.design: body += f"## Design\n\n{args.design}\n\n"
    if args.acceptance: body += f"## Acceptance Criteria\n\n{args.acceptance}\n\n"
        
    save_ticket(filepath, metadata, body)
    print(tid)

def cmd_next_id(args):
    """Exposes logic to finding the next available ID."""
    print(get_next_id(args.parent))

def cmd_status(args, status_override=None):
    path = find_ticket(args.id)
    new_status = status_override if status_override else args.status
    if new_status not in VALID_STATUSES:
        print(f"Error: invalid status", file=sys.stderr); sys.exit(1)
    meta, body = parse_ticket(path)
    meta['status'] = new_status
    save_ticket(path, meta, body)
    print(f"Updated {meta.get('id')} -> {new_status}")

def cmd_dep_manage(args, action):
    path = find_ticket(args.id)
    find_ticket(args.dep_id) 
    meta, body = parse_ticket(path)
    current_deps = meta.get('deps', [])
    if action == 'add':
        if args.dep_id not in current_deps:
            current_deps.append(args.dep_id)
            meta['deps'] = current_deps
            save_ticket(path, meta, body)
            print(f"Added dependency: {meta.get('id')} -> {args.dep_id}")
    elif action == 'remove':
        if args.dep_id in current_deps:
            current_deps.remove(args.dep_id)
            meta['deps'] = current_deps
            save_ticket(path, meta, body)
            print(f"Removed dependency: {meta.get('id')} -/-> {args.dep_id}")

def cmd_dep_tree(args):
    root_path = find_ticket(args.id)
    all_tickets = get_all_tickets()
    root_id = parse_ticket(root_path)[0].get('id')
    printed = set()

    def print_node(tid, prefix="", is_last=True, path_stack=None):
        if path_stack is None: path_stack = []
        if tid in path_stack: return
        t = all_tickets.get(tid)
        if not t: print(f"{prefix}??? ({tid})"); return
        
        status, effort = t['meta'].get('status', '?'), t['meta'].get('effort', 'medium')
        title = extract_title(t['body'])
        connector = "└── " if is_last else "├── "
        display = f"{tid} [{status}][{effort}] {title}"
        if prefix == "": print(display)
        else: print(f"{prefix}{connector}{display}")
            
        if not args.full and tid in printed and prefix != "": return
        printed.add(tid)
        
        deps = [d for d in t['meta'].get('deps', []) if d]
        # Sort deps numerically if possible
        deps.sort(key=lambda x: parse_semver(x) or (0,))
        valid_children = [d for d in deps if d in all_tickets]
        new_prefix = prefix + ("    " if is_last else "│   ")
        if prefix == "": new_prefix = ""
        for i, child_id in enumerate(valid_children):
            print_node(child_id, new_prefix, (i == len(valid_children) - 1), path_stack + [tid])

    print_node(root_id)

def cmd_link(args):
    paths = [find_ticket(i) for i in args.ids]
    tids = []
    file_data = []
    for p in paths:
        m, b = parse_ticket(p)
        tids.append(m.get('id'))
        file_data.append({'p': p, 'm': m, 'b': b})
    count = 0
    for i, data in enumerate(file_data):
        others = [t for j, t in enumerate(tids) if i != j]
        current = data['m'].get('links', [])
        changed = False
        for o in others:
            if o not in current: current.append(o); changed = True; count += 1
        if changed:
            data['m']['links'] = current
            save_ticket(data['p'], data['m'], data['b'])
    print(f"Linked {len(tids)} tickets" if count else "Already linked")

def cmd_unlink(args):
    path1 = find_ticket(args.id1)
    path2 = find_ticket(args.id2)
    m1, b1 = parse_ticket(path1)
    m2, b2 = parse_ticket(path2)
    id1, id2 = m1.get('id'), m2.get('id')
    if id2 in m1.get('links', []): m1['links'].remove(id2); save_ticket(path1, m1, b1)
    if id1 in m2.get('links', []): m2['links'].remove(id1); save_ticket(path2, m2, b2)
    print(f"Unlinked: {id1} <-> {id2}")

def cmd_ls(args):
    tickets = get_all_tickets()
    
    allowed_ids = None
    if args.scope:
        try:
            root_path = find_ticket(args.scope)
            root_id = parse_ticket(root_path)[0].get('id')
            allowed_ids = get_descendants(root_id, tickets)
            allowed_ids.add(root_id)
        except SystemExit: return

    t_list = []
    for tid, data in tickets.items():
        if args.status and data['meta'].get('status') != args.status: continue
        if allowed_ids is not None and tid not in allowed_ids: continue
        t_list.append((tid, data))
        
    # Semantic sort (1.2 < 1.10)
    t_list.sort(key=lambda x: parse_semver(x[0]) or (999999,))
    
    for tid, data in t_list:
        status, effort = data['meta'].get('status', 'open'), data['meta'].get('effort', 'medium')
        title = extract_title(data['body'])
        deps = data['meta'].get('deps', [])
        dep_str = (" <- [" + ", ".join(deps) + "]") if deps else ""
        print(f"{tid:<8} [{status}][{effort}] - {title}{dep_str}")

def cmd_ready_blocked(args, mode="ready"):
    tickets = get_all_tickets()
    
    allowed_ids = None
    if args.scope:
        try:
            root_path = find_ticket(args.scope)
            root_id = parse_ticket(root_path)[0].get('id')
            allowed_ids = get_descendants(root_id, tickets)
            allowed_ids.add(root_id)
        except SystemExit: return

    output_rows = []
    for tid, t in tickets.items():
        if allowed_ids is not None and tid not in allowed_ids: continue
        
        status = t['meta'].get('status', 'open')
        if status not in ['open', 'in_progress']: continue
            
        deps = t['meta'].get('deps', [])
        priority = str(t['meta'].get('priority', 2))
        effort = t['meta'].get('effort', 'medium')
        title = extract_title(t['body'])
        
        all_deps_closed = True
        open_blockers = []
        for d in deps:
            if d in tickets:
                if tickets[d]['meta'].get('status') != 'closed':
                    all_deps_closed = False
                    open_blockers.append(d)
            else: 
                all_deps_closed = False
                open_blockers.append(d + "(missing)")

        if mode == "ready" and all_deps_closed:
            output_rows.append({'p': priority, 'e': effort, 'id': tid, 's': status, 't': title})
        elif mode == "blocked" and not all_deps_closed:
             output_rows.append({'p': priority, 'e': effort, 'id': tid, 's': status, 't': title, 'b': open_blockers})
            
    # Sort by Priority, then Semantic ID
    output_rows.sort(key=lambda x: (x['p'], parse_semver(x['id']) or (999999,)))
    
    for r in output_rows:
        if mode == "ready":
            print(f"{r['id']:<8} [P{r['p']}][{r['e']:<7}][{r['s']}] - {r['t']}")
        else:
            blockers_str = "[" + ", ".join(r['b']) + "]"
            print(f"{r['id']:<8} [P{r['p']}][{r['e']:<7}][{r['s']}] - {r['t']} <- {blockers_str}")

def cmd_closed(args):
    tickets = get_all_tickets()
    closed = []
    for tid, t in tickets.items():
        if t['meta'].get('status') in ['closed', 'done']:
            closed.append((os.path.getmtime(t['path']), tid, t))
    closed.sort(key=lambda x: x[0], reverse=True)
    limit = int(args.limit) if args.limit else 20
    for _, tid, t in closed[:limit]:
        status, effort = t['meta'].get('status'), t['meta'].get('effort', 'medium')
        title = extract_title(t['body'])
        print(f"{tid:<8} [{status}][{effort}] - {title}")

def cmd_show(args):
    target_path = find_ticket(args.id)
    target_meta, _ = parse_ticket(target_path)
    target_id = target_meta.get('id')
    all_tickets = get_all_tickets()
    
    with open(target_path, 'r') as f: lines = f.readlines()
    in_fm = False
    for line in lines:
        if line.strip() == '---': in_fm = not in_fm; print(line, end=''); continue
        if in_fm and line.startswith('parent:'):
            parent_id = line.split(':', 1)[1].strip()
            if parent_id in all_tickets:
                print(f"{line.strip()}  # {extract_title(all_tickets[parent_id]['body'])}")
            else: print(line, end='')
        else: print(line, end='')
            
    blockers, blocking, children, linked = [], [], [], []
    for dep_id in target_meta.get('deps', []):
        if dep_id in all_tickets and all_tickets[dep_id]['meta'].get('status') != 'closed': blockers.append(dep_id)
    for tid, t in all_tickets.items():
        if tid == target_id: continue
        if target_id in t['meta'].get('deps', []) and t['meta'].get('status') != 'closed': blocking.append(tid)
        if t['meta'].get('parent') == target_id: children.append(tid)
    for link_id in target_meta.get('links', []):
        if link_id in all_tickets: linked.append(link_id)
            
    def print_list(header, ids):
        if not ids: return
        print(f"\n## {header}\n")
        ids.sort(key=lambda x: parse_semver(x) or (999999,))
        for i in ids:
            t = all_tickets.get(i)
            print(f"- {i} [{t['meta'].get('status','?')}] {extract_title(t['body'])}")

    print_list("Blockers", blockers); print_list("Blocking", blocking)
    print_list("Children", children); print_list("Linked", linked)

def cmd_add_note(args):
    path = find_ticket(args.id)
    if args.note: text = " ".join(args.note)
    elif not sys.stdin.isatty(): text = sys.stdin.read().strip()
    else: print("Error: no note provided", file=sys.stderr); sys.exit(1)
    with open(path, 'r') as f: content = f.read()
    if "## Notes" not in content: content += "\n\n## Notes\n"
    content += f"\n**{get_iso_date()}**\n\n{text}\n"
    with open(path, 'w') as f: f.write(content)
    print(f"Note added to {os.path.basename(path).replace('.md','')}")

def cmd_query(args):
    tickets = get_all_tickets()
    output = []
    for tid, t in tickets.items():
        obj = t['meta'].copy()
        obj['title'] = extract_title(t['body'])
        output.append(obj)
    json_str = json.dumps(output)
    if args.filter:
        try:
            p = subprocess.Popen(['jq', args.filter], stdin=subprocess.PIPE, stdout=subprocess.PIPE, text=True)
            out, _ = p.communicate(input=json_str); print(out)
        except: print(json_str)
    else: print(json_str)

def cmd_edit(args):
    path = find_ticket(args.id)
    if sys.stdout.isatty(): subprocess.call([os.environ.get('EDITOR', 'vi'), path])
    else: print(f"Edit ticket file: {path}")

# --- Argument Parsing ---

def main():
    parser = argparse.ArgumentParser(description="minimal ticket system")
    subparsers = parser.add_subparsers(dest="command")

    p_create = subparsers.add_parser("create", help="Create ticket")
    p_create.add_argument("title", nargs="?", help="Title")
    p_create.add_argument("--id", dest="id_override", help="Manual ID (e.g. 1.2)")
    p_create.add_argument("--parent", help="Auto-number as child of Parent ID")
    p_create.add_argument("--epic", action="store_true", help="Auto-number as next Major Epic")
    p_create.add_argument("-d", "--description", help="Description")
    p_create.add_argument("--design", help="Design notes")
    p_create.add_argument("--acceptance", help="Acceptance criteria")
    p_create.add_argument("-t", "--type", default="task", help="Type")
    p_create.add_argument("-p", "--priority", default=2, type=int, help="Priority 0-4")
    p_create.add_argument("-e", "--effort", default="medium", choices=VALID_EFFORTS, help="Effort")
    p_create.add_argument("-a", "--assignee", help="Assignee")
    p_create.add_argument("--external-ref", help="Ref")

    p_next = subparsers.add_parser("next-id", help="Get next available ID")
    p_next.add_argument("parent", nargs="?", help="Optional parent ID")

    p_start = subparsers.add_parser("start", help="Start")
    p_start.add_argument("id")

    p_close = subparsers.add_parser("close", help="Close")
    p_close.add_argument("id")
    
    p_reopen = subparsers.add_parser("reopen", help="Reopen")
    p_reopen.add_argument("id")
    
    p_status = subparsers.add_parser("status", help="Set status")
    p_status.add_argument("id")
    p_status.add_argument("status", choices=VALID_STATUSES)

    p_dep = subparsers.add_parser("dep", help="Dependencies")
    p_dep.add_argument("id_or_cmd")
    p_dep.add_argument("dep_id", nargs="?")
    p_dep.add_argument("--full", action="store_true")

    p_undep = subparsers.add_parser("undep", help="Rm Dep")
    p_undep.add_argument("id")
    p_undep.add_argument("dep_id")

    p_link = subparsers.add_parser("link", help="Link")
    p_link.add_argument("ids", nargs="+")

    p_unlink = subparsers.add_parser("unlink", help="Unlink")
    p_unlink.add_argument("id1")
    p_unlink.add_argument("id2")

    p_ls = subparsers.add_parser("ls", help="List")
    p_ls.add_argument("--status", help="Filter status")
    p_ls.add_argument("scope", nargs="?", help="Scope ID (root)")

    p_ready = subparsers.add_parser("ready", help="List ready")
    p_ready.add_argument("scope", nargs="?", help="Scope ID (root)")
    
    p_blocked = subparsers.add_parser("blocked", help="List blocked")
    p_blocked.add_argument("scope", nargs="?", help="Scope ID (root)")
    
    p_closed = subparsers.add_parser("closed", help="List closed")
    p_closed.add_argument("--limit", type=int, default=20)

    p_show = subparsers.add_parser("show", help="Show")
    p_show.add_argument("id")

    p_edit = subparsers.add_parser("edit", help="Edit")
    p_edit.add_argument("id")

    p_note = subparsers.add_parser("add-note", help="Note")
    p_note.add_argument("id")
    p_note.add_argument("note", nargs="*")

    p_query = subparsers.add_parser("query", help="JSON")
    p_query.add_argument("filter", nargs="?")

    args = parser.parse_args()
    if not args.command: parser.print_help(); sys.exit(1)

    try:
        if args.command == "create": cmd_create(args)
        elif args.command == "next-id": cmd_next_id(args)
        elif args.command == "start": cmd_status(args, "in_progress")
        elif args.command == "close": cmd_status(args, "closed")
        elif args.command == "reopen": cmd_status(args, "open")
        elif args.command == "status": cmd_status(args)
        elif args.command == "dep":
            if args.id_or_cmd == "tree": args.id = args.dep_id; cmd_dep_tree(args)
            else: args.id = args.id_or_cmd; cmd_dep_manage(args, "add")
        elif args.command == "undep": cmd_dep_manage(args, "remove")
        elif args.command == "link": cmd_link(args)
        elif args.command == "unlink": cmd_unlink(args)
        elif args.command == "ls": cmd_ls(args)
        elif args.command == "ready": cmd_ready_blocked(args, "ready")
        elif args.command == "blocked": cmd_ready_blocked(args, "blocked")
        elif args.command == "closed": cmd_closed(args)
        elif args.command == "show": cmd_show(args)
        elif args.command == "edit": cmd_edit(args)
        elif args.command == "add-note": cmd_add_note(args)
        elif args.command == "query": cmd_query(args)
    except KeyboardInterrupt: sys.exit(130)

if __name__ == "__main__": main()
