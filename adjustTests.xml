function matchBook(input: string): string | null {
    const normalized = input.toLowerCase().replace(/\s+/g, "");
    for (const [id, aliases] of Object.entries(BOOK_ALIASES)) {
        if (
            aliases.some(
                (alias) =>
                    normalized.startsWith(alias) ||
                    normalized === id.toLowerCase(),
            )
        ) {
            return id;
        }
    }
