    "@types/moo": "0.5.10",
    "@types/node": "24.10.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@types/react-highlight-words": "^0.20.0",
    "@vanilla-extract/vite-plugin": "^5.1.1",
    "@vitejs/plugin-react": "4.7.0",
    "fake-indexeddb": "^6.2.5",
