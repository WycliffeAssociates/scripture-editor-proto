    "@lingui/react": "5.5.2",
    "@mantine/core": "8.3.7",
    "@mantine/hooks": "8.3.7",
    "@mantine/notifications": "^8.3.7",
    "@tailwindcss/vite": "4.1.17",
    "@tanstack/react-query": "5.90.7",
    "@tanstack/react-router": "1.135.0",
    "@tanstack/react-router-devtools": "1.135.0",
    "@tauri-apps/api": "2.9.0",
