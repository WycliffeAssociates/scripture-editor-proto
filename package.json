    "postcss": "8.5.6",
    "postcss-preset-mantine": "1.18.0",
    "postcss-simple-vars": "7.0.1",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "vite": "7.2.2",
    "vitest": "3.2.4",
    "wrangler": "4.46.0"
