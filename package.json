    "@lingui/react": "5.5.2",
    "@mantine/core": "8.3.8",
    "@mantine/hooks": "8.3.8",
    "@mantine/notifications": "^8.3.8",
    "@mantine/vanilla-extract": "^8.3.8",
    "@tanstack/react-query": "5.90.7",
    "@tanstack/react-router": "1.135.0",
    "@tanstack/react-virtual": "^3.13.12",
    "@tauri-apps/api": "2.9.0",
    "@tauri-apps/plugin-dialog": "~2.4.2",
    "@tauri-apps/plugin-fs": "2.4.4",
    "@tauri-apps/plugin-opener": "~2",
    "@tauri-apps/plugin-os": "~2",
    "@vanilla-extract/css": "^1.17.4",
    "buffer": "^6.0.3",
    "crypto-es": "^3.1.2",
    "dexie": "^4.2.1",
    "diff": "8.0.2",
    "fflate": "0.8.2",
    "isomorphic-git": "^1.37.2",
    "lexical": "0.35.0",
    "lucide-react": "0.542.0",
    "moo": "0.5.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-highlight-words": "^0.21.0",
    "react-use": "17.6.0",
    "usfm-onion-web": "github:WycliffeAssociates/usfm-onion#b8d90290c2edcab6e4fcf69e2534e2a2762485bb",
    "valibot": "^1.1.0",
    "yaml": "2.8.1"
