{
  "name": "dovetail",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev.tauri": "vite --config vite.tauri.config.ts",
    "dev.web": "vite dev --config vite.web.config.ts --port 5175",
    "build.tauri": "vite build --config vite.tauri.config.ts",
    "build.web": "vite build --config vite.web.config.ts",
    "preview": "vite preview --outDir ./dist-web",
    "tauri": "tauri",
    "tauri-dev": "tauri dev",
    "tauri-build": "tauri build",
    "lingui": "lingui",
    "lingui-extract": "lingui extract",
    "lingui-compile": "lingui compile --typescript",
    "check": "tsc --noEmit",
    "format": "biome check --write .",
    "test": "vitest",
    "test.e2e.ui": "pnpm exec playwright test --ui",
    "test.e2e": "pnpm exec playwright test",
    "test:unit": "vitest run --exclude 'src/**/*.integration.ts'",
    "test:integration": "TAURI_TEST_INTEGRATION=true vitest run --exclude 'src/**/*.test.ts'",
    "test:watch": "vitest --watch",
    "knip": "knip",
    "check:architecture": "node scripts/checkArchitecture.mjs"
  },
  "dependencies": {
    "@lexical/headless": "0.35.0",
    "@lexical/react": "0.35.0",
