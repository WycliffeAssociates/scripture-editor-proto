    "@tauri-apps/plugin-window-state": "2.4.1",
    "@vanilla-extract/css": "^1.17.4",
    "@mantine/vanilla-extract": "^8.3.8",
    "diff": "8.0.2",
    "fflate": "0.8.2",
    "lexical": "0.35.0",
    "lucide-react": "0.542.0",
    "moo": "0.5.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-use": "17.6.0",
