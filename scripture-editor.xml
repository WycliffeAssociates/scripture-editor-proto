fn parse_attribute_pair<'i>(attr_text: &'i str) -> Option<(&'i str, &'i str)> {
    // PERF: Captures now return borrowed &'i str, no String allocation.
    ATTRIBUTE_RE.captures(attr_text).and_then(|caps| {
        let k = caps.get(1)?.as_str();
        let v = caps.get(2)?.as_str();
        Some((k, v))
    })
}

fn create_parsed_token<'i>(token: &Token<'i>) -> ParsedToken<'i> {
    // PERF: No more `format!`, no String clones.
    let level = if is_marker(token.text) {
        MARKER_LEVEL_RE
            .captures(token.text)
            .and_then(|caps| caps.get(1).map(|m| m.as_str()))
    } else {
        None
    };

    ParsedToken {
        kind: token.kind,
        text: token.text,
        span: token.span,
        level,
        content: vec![],
        attributes: HashMap::new(),
    }
}

fn parse_token_stream<'i>(tokens: &[Token<'i>]) -> Vec<ParsedToken<'i>> {
    let mut result: Vec<ParsedToken<'i>> = Vec::new();

    // PERF: The stack now stores indices, not references. This is the key to
    // satisfying the borrow checker. It represents the path to the current parent.
    // e.g., `[0, 2]` means `result[0].content[2]`
    let mut stack: Vec<usize> = Vec::new();

    for token in tokens {
        // --- Handle Attribute Tokens ---
        // Attributes apply to the most recently added node at the current depth.
        if token.kind == TokenKind::AttrPair {
            // 1. Get a mutable reference to the current parent's content Vec.
            let mut current_level = &mut result;
            for &index in &stack {
                current_level = &mut current_level[index].content;
            }

            // 2. Modify the last node in that Vec.
            if let Some(last_node) = current_level.last_mut() {
                if is_marker(last_node.text) {
                    if let Some((k, v)) = parse_attribute_pair(token.text) {
                        last_node.attributes.insert(k, v);
                    }
                }
            }
            continue;
        }

        // --- Handle Closing Markers ---
        if is_end_marker(token.kind) {
            // A closing tag just means we go up one level in the hierarchy.
            stack.pop();
            continue;
        }

        // --- Handle Opening / Standalone Tokens ---
        let parsed_token = create_parsed_token(token);

        // 1. Get a mutable reference to the parent's content Vec by walking the path.
        // This is the "get current" step.
        let parent_content = {
            let mut current = &mut result;
            for &index in &stack {
                // Get the node at the index, then get a reference to its content vec
                current = &mut current[index].content;
            }
            current
        };

        // 2. Move the new token into the parent's content.
        parent_content.push(parsed_token);

        // 3. If the token we just added is a container, update the path.
        // The new path is the old path plus the index of the element we just added.
        if TOKENS_EXPECTING_CLOSE.contains(&token.kind) {
            let new_index = parent_content.len() - 1;
            stack.push(new_index);
        }
    }

    result
}

pub fn is_marker(text: &str) -> bool {
    text.starts_with('\\')
}

// is_end_marker now takes a TokenKind directly
pub fn is_end_marker(kind: TokenKind) -> bool {
    matches!(
        kind,
        TokenKind::ImplicitClose
            | TokenKind::QtMilestoneEnd
            | TokenKind::TsMilestoneEnd
            | TokenKind::ZMilestoneEnd
            | TokenKind::AddEnd
            | TokenKind::AddpnEnd
            | TokenKind::BdEnd
            | TokenKind::BditEnd
            | TokenKind::BkEnd
            | TokenKind::CatEnd
            | TokenKind::DcEnd
            | TokenKind::EfEnd
            | TokenKind::EmEnd
            | TokenKind::EsbEnd
            | TokenKind::ExEnd
            | TokenKind::FEnd
            | TokenKind::FdcEnd
            | TokenKind::FeEnd
            | TokenKind::FigEnd
            | TokenKind::FkEnd
            | TokenKind::FlEnd
            | TokenKind::FmEnd
            | TokenKind::FpEnd
            | TokenKind::FqEnd
            | TokenKind::FqaEnd
            | TokenKind::FrEnd
            | TokenKind::FtEnd
            | TokenKind::FvEnd
            | TokenKind::FwEnd
            | TokenKind::IorEnd
            | TokenKind::IqtEnd
            | TokenKind::ItEnd
            | TokenKind::JmpEnd
            | TokenKind::KEnd
            | TokenKind::LikEnd
            | TokenKind::LitlEnd
            | TokenKind::LivEnd
            | TokenKind::NdEnd
            | TokenKind::NoEnd
            | TokenKind::OrdEnd
            | TokenKind::PnEnd
            | TokenKind::PngEnd
            | TokenKind::QasEnd
            | TokenKind::QsEnd
            | TokenKind::QtEnd
            | TokenKind::RbEnd
            | TokenKind::RefEnd
            | TokenKind::RqEnd
            | TokenKind::ScEnd
            | TokenKind::SigEnd
            | TokenKind::SlsEnd
            | TokenKind::SupEnd
            | TokenKind::TlEnd
            | TokenKind::WEnd
            | TokenKind::WaEnd
            | TokenKind::WgEnd
            | TokenKind::WhEnd
            | TokenKind::WjEnd
            | TokenKind::XEnd
            | TokenKind::XdcEnd
            | TokenKind::XkEnd
            | TokenKind::XntEnd
            | TokenKind::XoEnd
            | TokenKind::XopEnd
            | TokenKind::XotEnd
            | TokenKind::XqEnd
            | TokenKind::XtEnd
            | TokenKind::XtaEnd
    )
}

// PERF: The function now works with the borrowed `ParsedToken<'i>`
pub fn organize_by_chapters<'i>(tokens: Vec<ParsedToken<'i>>) -> ParsedUSFM<'i> {
    // 1. PRE-COMPUTATION PASS: Find the start index of every chapter marker.
    // We iterate once to find all `TokenKind::C` and store their positions.
    let chapter_start_indices: Vec<usize> = tokens
        .iter()
        .enumerate()
        .filter(|(_i, token)| token.kind == TokenKind::C)
        .map(|(i, _token)| i)
        .collect();

    // If there are no chapter markers at all, the entire document is the intro.
    if chapter_start_indices.is_empty() {
        return ParsedUSFM {
            intro: tokens, // We can move the whole vector, no clone needed.
            chapters: HashMap::new(),
        };
    }

    // --- SLICING AND ORGANIZATION ---

    // 2. The intro is everything from the beginning up to the first chapter marker.
    let first_chapter_index = chapter_start_indices[0];
    let intro = tokens[0..first_chapter_index].to_vec(); // .to_vec() creates an owned copy

    // 3. Create chapter chunks using the pre-computed indices.
    let mut chapters = HashMap::new();

    // Create an iterator that gives us the start and end index for each chapter's slice.
    // We chain the list of start indices with the total length of the token vec,
    // then use `.windows(2)` to create pairs like `[start1, start2]`, `[start2, start3]`, etc.
    let ranges = chapter_start_indices
        .iter()
        .map(|&i| i) // Convert `&usize` to `usize`
        .chain(std::iter::once(tokens.len()));

    for window in ranges.collect::<Vec<_>>().windows(2) {
        let start_index = window[0];
        let end_index = window[1];

        // Get the slice of tokens for the current chapter.
        let chapter_tokens = &tokens[start_index..end_index];

        // The first token is `\c`. The token *after* it should contain the number.
        // A robust parser would validate this structure carefully.
        if chapter_tokens.len() > 1 {
            let number_token = &chapter_tokens[1];
            // Trim whitespace and parse the text to a u32 for the HashMap key.
            if let Ok(chapter_num) = number_token.text.trim().parse::<u32>() {
                // Insert an owned copy of the slice into the map.
                chapters.insert(chapter_num, chapter_tokens.to_vec());
            } else {
                // Handle the case where a `\c` is not followed by a valid number.
                // For now, we'll just skip this malformed chapter.
                println!("Warning: Malformed chapter marker at index {}", start_index);
            }
        }
    }

    ParsedUSFM { intro, chapters }
}

pub fn parse_usfm(input: &str) -> ParsedUSFM {
    let lexer = TokenKind::lexer(input);
    let tokens: Vec<Token> = lexer
        .spanned()
        .filter_map(|(res_kind, span)| {
            // res_kind: Result<TokenKind, ()>
            let span = (span.start, span.end);
            if let Ok(kind) = res_kind {
                Some(Token {
                    text: &input[span.0..span.1],
                    span,
                    kind,
                })
            } else {
                None // or handle error in some way
            }
        })
        .collect();

    // push_whitespace_onto_prev_token(&mut tokens);

    let parsed_tokens = parse_token_stream(&tokens);
    let organized = organize_by_chapters(parsed_tokens);

    organized
}
