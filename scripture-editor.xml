<file path=".github/workflows/release2.yaml">
name: Release v2

on:
  # push:
  #   tags:
  #     - "v*"
  push:
    # Sequence of patterns matched against refs/heads
    branches:
      - wk-11-11-25
  workflow_dispatch:

jobs:
  ensure-versions-synced:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Validate version parity
        run: |
          set -euo pipefail
          pkg=$(node -p "require('./package.json').version")
          # Run sync script to ensure Cargo.toml matches package.json
          node scripts/syncVersions.js
          # Now verify all are in sync
          cargo=$(sed -n 's/^version = "\(.*\)"/\1/p' ./src/tauri/rust/Cargo.toml | head -n1)
          echo "package.json: $pkg"
          echo "src/tauri/rust/Cargo.toml: $cargo"
          echo "src/tauri/rust/tauri.conf.json: points to ../package.json"
          if [ "$pkg" != "$cargo" ]; then
            echo "Version mismatch detected between package.json and src/tauri/rust/Cargo.toml"
            exit 1
          fi
  build-tauri-frontend:
    needs: ensure-versions-synced
    permissions:
      contents: write
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Install pnpm
        uses: pnpm/action-setup@v4
        with:
          version: 10
      - name: Install Node
        uses: actions/setup-node@v4
        with:
          node-version: 24.4.1
          cache: "pnpm"
      - name: Install dependencies
        run: pnpm install
      - name: Build tauri frontend
        run: pnpm build.tauri

      - name: Upload tauri frontend
        uses: actions/upload-artifact@v4
        with:
          name: frontend-dist
          path: dist

  build-desktops:
    needs: build-tauri-frontend
    permissions:
      contents: write
    strategy:
      fail-fast: false
      matrix:
        include:
          # macOS arm64 and x64
          - os: macos-latest
            args: "--target universal-apple-darwin"
            artifact_paths: |
              src/tauri/rust/target/universal-apple-darwin/release/bundle/macos/*.dmg
              src/tauri/rust/target/universal-apple-darwin/release/bundle/macos/*.app

          # Windows
          - os: windows-latest
            args: ""
            artifact_paths: |
              src/tauri/rust/target/release/bundle/nsis/*.exe
              src/tauri/rust/target/release/bundle/msi/*.msi

          # Linux desktop
          - os: ubuntu-22.04
            args: ""
            artifact_paths: |
              src/tauri/rust/target/release/bundle/appimage/*.AppImage
              src/tauri/rust/target/release/bundle/deb/*.deb
              src/tauri/rust/target/release/bundle/rpm/*.rpm

    runs-on: ${{ matrix.os }}

    steps:
      - uses: actions/checkout@v4
      - name: Source Secrets
        id: secrets
        uses: 1password/load-secrets-action@v3
        env:
          OP_SERVICE_ACCOUNT_TOKEN: ${{ secrets.OP_SERVICE_ACCOUNT_TOKEN }}
          APPLE_CERTIFICATE: "op://DevOps/Scripture-Editor/p12-b64"
          APPLE_CERTIFICATE_PASSWORD: "op://DevOps/Scripture-Editor/apple-p12-cert-password"
          KEYCHAIN_PASSWORD: "op://DevOps/Scripture-Editor/keychain-password"
          APP_STORE_CONNECT_KEY: "op://DevOps/Scripture-Editor/app-store-connect-p8-b64"
          APP_STORE_API_ISSUER: "op://DevOps/Scripture-Editor/app-store-connect-api-issuer"
          APP_STORE_API_KEY_ID: "op://DevOps/Scripture-Editor/app-store-connect-api-key-id"

      - name: Decode App Store Connect Key
        if: matrix.os == 'macos-latest'
        shell: bash
        env:
          APP_STORE_CONNECT_KEY: ${{ steps.secrets.outputs.APP_STORE_CONNECT_KEY }}
        run: |
          echo "Decoding APP_STORE_CONNECT_KEY..."
          echo "Length: ${#APP_STORE_CONNECT_KEY}"
          echo "$APP_STORE_CONNECT_KEY" | base64 --decode > app-store-connect.p8
          echo "APPLE_API_KEY_PATH=$(pwd)/app-store-connect.p8" >> $GITHUB_ENV
          echo "Decoded successfully"

      - name: Decode Apple Certificate
        if: matrix.os == 'macos-latest'
        shell: bash
        env:
          APPLE_CERTIFICATE: ${{ steps.secrets.outputs.APPLE_CERTIFICATE }}
        run: |
          echo "Decoding APPLE_CERTIFICATE..."
          echo "Length: ${#APPLE_CERTIFICATE}"
          echo "$APPLE_CERTIFICATE" | base64 --decode > certificate.p12
          echo "Decoded successfully"

      - name: Create and Unlock Keychain
        if: matrix.os == 'macos-latest'
        shell: bash
        env:
          KEYCHAIN_PASSWORD: ${{ steps.secrets.outputs.KEYCHAIN_PASSWORD }}
        run: |
          echo "Creating keychain..."
          security create-keychain -p "$KEYCHAIN_PASSWORD" build.keychain
          security default-keychain -s build.keychain
          security unlock-keychain -p "$KEYCHAIN_PASSWORD" build.keychain
          security set-keychain-settings -t 3600 -u build.keychain
          echo "Keychain ready"

      - name: Import Certificate
        if: matrix.os == 'macos-latest'
        shell: bash
        env:
          APPLE_CERTIFICATE_PASSWORD: ${{ steps.secrets.outputs.APPLE_CERTIFICATE_PASSWORD }}
          KEYCHAIN_PASSWORD: ${{ steps.secrets.outputs.KEYCHAIN_PASSWORD }}
        run: |
          echo "Importing certificate..."
          security import certificate.p12 -k build.keychain -P "$APPLE_CERTIFICATE_PASSWORD" -T /usr/bin/codesign
          echo "Certificate imported"

      - name: Set Key Partition List
        if: matrix.os == 'macos-latest'
        shell: bash
        env:
          KEYCHAIN_PASSWORD: ${{ steps.secrets.outputs.KEYCHAIN_PASSWORD }}
        run: |
          echo "Setting key partition list..."
          security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k "$KEYCHAIN_PASSWORD" build.keychain
          echo "Key partition list set"

      - name: Verify Code Signing Identities
        if: matrix.os == 'macos-latest'
        shell: bash
        run: |
          echo "Checking code signing identities..."
          security find-identity -v -p codesigning build.keychain

      - name: Verify Certificate
        if: matrix.os == 'macos-latest'
        run: |
          CERT_INFO=$(security find-identity -v -p codesigning build.keychain | grep "Developer ID Application")
          CERT_ID=$(echo "$CERT_INFO" | awk -F'"' '{print $2}')
          echo "CERT_ID=$CERT_ID" >> $GITHUB_ENV
          echo "Certificate imported."

      - name: Download frontend dist
        uses: actions/download-artifact@v4
        with:
          name: frontend-dist
          path: dist

      - name: Setup pnpm
        uses: pnpm/action-setup@v4
        with:
          version: 10
      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: 24.4.1
          cache: "pnpm"
      - name: Install dependencies
        run: pnpm install

      - name: Install Rust stable
        uses: dtolnay/rust-toolchain@stable
        with:
          # Those targets are only used on macos runners so it's in an `if` to slightly speed up windows and linux builds.
          targets: ${{ matrix.os == 'macos-latest' && 'aarch64-apple-darwin,x86_64-apple-darwin' || '' }}
      - name: Rust cache
        uses: swatinem/rust-cache@v2
        with:
          workspaces: "./src/tauri/rust -> target"

      - name: Install Linux deps
        if: matrix.os == 'ubuntu-22.04'
        run: |
          sudo apt-get update
          sudo apt-get install -y \
            libwebkit2gtk-4.0-dev \
            libwebkit2gtk-4.1-dev \
            libappindicator3-dev \
            librsvg2-dev \
            patchelf

      - name: Build + Release
        uses: tauri-apps/tauri-action@v0
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          # APPLE_CERTIFICATE: ${{ steps.secrets.outputs.APPLE_CERTIFICATE }}
          # APPLE_CERTIFICATE_PASSWORD: ${{ steps.secrets.outputs.APPLE_CERTIFICATE_PASSWORD }}
          APPLE_SIGNING_IDENTITY: ${{ env.CERT_ID }}
          APPLE_API_ISSUER: ${{ steps.secrets.outputs.APP_STORE_API_ISSUER }}
          APPLE_API_KEY: ${{ steps.secrets.outputs.APP_STORE_API_KEY_ID }}
          APPLE_API_KEY_PATH: ${{ env.APPLE_API_KEY_PATH }}
        with:
          tagName: ${{ github.ref_name }}
          releaseName: ${{ github.ref_name }}
          releaseDraft: false
          prerelease: true
          # doesn't run prebuild script: Expect assets already built at dist
          args: ${{ matrix.args }} --config ./src/tauri/rust/tauri.conf.ci_cache.json --verbose --ci

      - name: Upload desktop artifacts
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: ${{ matrix.os }}-build
          path: ${{ matrix.artifact_paths }}

  build-android:
    runs-on: ubuntu-22.04
    needs: [build-tauri-frontend]
    steps:
      - uses: actions/checkout@v4

      - name: Download frontend dist
        uses: actions/download-artifact@v4
        with:
          name: frontend-dist
          path: dist

      - name: Install Rust stable
        uses: dtolnay/rust-toolchain@stable
        with:
          targets: aarch64-linux-android,armv7-linux-androideabi,i686-linux-android,x86_64-linux-android

      - name: Install Linux deps for tauri
        if: matrix.os == 'ubuntu-22.04'
        run: |
          sudo apt-get update
          sudo apt-get install -y \
            libwebkit2gtk-4.0-dev \
            libwebkit2gtk-4.1-dev \
            libappindicator3-dev \
            librsvg2-dev \
            patchelf

      - name: Setup pnpm
        uses: pnpm/action-setup@v4
        with:
          version: 10
      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: 24.4.1
          cache: "pnpm"
      - name: Install frontend dependencies
        run: pnpm install

      - name: Setup Java 17
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: 17

      - name: Setup Android SDK & NDK
        uses: android-actions/setup-android@v3
        with:
          packages: "tools platform-tools build-tools;34.0.0"

      - name: Install SDK / Build-tools / NDK and verify apksigner
        run: |
          sdkmanager --install "platforms;android-34" "ndk;25.2.9519653"
          echo "$ANDROID_SDK_ROOT/build-tools/34.0.0" >> $GITHUB_PATH
          which apksigner || echo "apksigner not found in PATH"
          apksigner --version || echo "apksigner not executable"

      - name: Add Android NDK toolchain to PATH
        run: |
          echo "$ANDROID_NDK_ROOT/toolchains/llvm/prebuilt/linux-x86_64/bin" >> $GITHUB_PATH

      - name: Export NDK_HOME
        run: echo "NDK_HOME=$ANDROID_NDK_ROOT" >> $GITHUB_ENV

      - name: build android apk and aab
        run: pnpm tauri android build --ci --config ./src/tauri/rust/tauri.conf.ci_cache.json

      - name: List Android build outputs
        shell: bash
        run: |
          echo "Checking Android build outputs:"
          ls -la ./src/tauri/rust/gen/android/app/build/outputs/apk/universal/release/ || echo "APK directory not found"
          ls -la ./src/tauri/rust/gen/android/app/build/outputs/bundle/universalRelease/ || echo "AAB directory not found"

      - name: Rename Android files
        shell: bash
        run: |
          # Get version from package.json
          VERSION=$(node -p "require('./package.json').version")

          # Rename APK file
          if [ -f "./src/tauri/rust/gen/android/app/build/outputs/apk/universal/release/app-universal-release.apk" ]; then
            mv "./src/tauri/rust/gen/android/app/build/outputs/apk/universal/release/app-universal-release.apk" \
               "./src/tauri/rust/gen/android/app/build/outputs/apk/universal/release/refiner-v${VERSION}-universal.apk"
            echo "Renamed APK to: refiner-v${VERSION}-universal.apk"
          fi

          # Rename AAB file
          if [ -f "./src/tauri/rust/gen/android/app/build/outputs/bundle/universalRelease/app-universal-release.aab" ]; then
            mv "./src/tauri/rust/gen/android/app/build/outputs/bundle/universalRelease/app-universal-release.aab" \
               "./src/tauri/rust/gen/android/app/build/outputs/bundle/universalRelease/refiner-v${VERSION}-universal.aab"
            echo "Renamed AAB to: refiner-v${VERSION}-universal.aab"
          fi

          # List renamed files
          echo "Final Android build outputs:"
          ls -la ./src/tauri/rust/gen/android/app/build/outputs/apk/universal/release/
          ls -la ./src/tauri/rust/gen/android/app/build/outputs/bundle/universalRelease/

      - name: Upload Android artifacts
        uses: actions/upload-artifact@v4
        with:
          name: android-builds
          path: |
            ./src/tauri/rust/gen/android/app/build/outputs/apk/universal/release/*.apk
            ./src/tauri/rust/gen/android/app/build/outputs/bundle/universalRelease/*.aab
