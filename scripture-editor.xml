// This is a “sub-lexer” for inside the \id context
#[derive(Logos, Debug, PartialEq, Clone)]
pub enum IdExtras {
    #[regex(r"[A-Z1-9]{3}")]
    BookCode,
    #[regex(r"[ \t]+")]
    Ws,
}

fn id_callback(lex: &mut logos::Lexer<TokenKind>) -> Option<()> {
    // Morph into sub-lexer for the ID extras
    let mut sub_lexer = lex.clone().morph::<IdExtras>();

    while let Some(token) = sub_lexer.next() {
        match token {
            Ok(IdExtras::BookCode) => {
                // Here we could push a BookCode token somewhere in your parser
                // Or just let the main lexer pick it up naturally
                break; // stop after finding the first BookCode
            }
            _ => {}
        }
    }

    // Morph back to main lexer so it continues lexing after what sub-lexer consumed
    *lex = sub_lexer.morph();

    Some(())
}

