    const projectsDirMock = new MockDirectoryHandle(
      `${MOCK_USER_DATA_DIR}/projects`,
      {
        [MOCK_PROJECT_ID_1]: {
          kind: "directory",
          entries: {
            "project.json": MOCK_PROJECT_1,
          },
        },
      },
