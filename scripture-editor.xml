  //     id: t.id,
  //     sid: t.sid || "",
  //     tokenType: "endMarker",
  //     marker: t.marker,
  //     inPara: t.inPara,
  //   });
  //   return createSerializedUSFMElementNode(t, languageDirection, [
  //     openSerializedMarker,
  //     ...children,
  //     close,
  //   ]);
  // }

  // if (token.marker === "b") {
  //   const lb: SerializedLineBreakNode = {
  //     type: "linebreak",
  //     version: 1,
  //   };
  //   return lb;
  // }
  if (token.tokenType === TokenMap.verticalWhitespace) {
    const lb: SerializedLineBreakNode = {
